    {
      "parameters": {
        "language": "python",
        "pythonCode": "from bs4 import BeautifulSoup\n\ndef extract_hidden_email_history(html_body):\n    soup = BeautifulSoup(html_body, \"html.parser\")\n\n    # Extract content from <blockquote> tags\n    blockquotes = soup.find_all(\"blockquote\")\n    blockquote_texts = [b.get_text(\"\\n\", strip=True) for b in blockquotes]\n\n    # Extract content from Gmail-style <div class=\"gmail_quote\">\n    gmail_quotes = soup.find_all(\"div\", class_=\"gmail_quote\")\n    gmail_quote_texts = [g.get_text(\"\\n\", strip=True) for g in gmail_quotes]\n\n    # Combine all extracted hidden parts\n    hidden_parts = blockquote_texts + gmail_quote_texts\n\n    return \"\\n\\n--- Hidden Email Thread Start ---\\n\\n\" + \"\\n\\n\".join(hidden_parts) if hidden_parts else \"No hidden content found.\"\n\n# Get first item's \"body\" field\nhtml_email_body = items[0][\"json\"][\"body\"]\n\n# Output result in the format n8n expects\nreturn {\n    \"json\": {\n        \"hidden_history\": extract_hidden_email_history(html_email_body)\n    }\n}"
      },
