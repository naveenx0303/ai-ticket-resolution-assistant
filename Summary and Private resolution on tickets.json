    {
      "parameters": {
        "jsCode": "const items = $input.all().map((item) => item.json);\nconst emailRegex = /\\S+@\\S+\\.\\S+/g;\nconst signatureRegex = /--\\s*\\n(.*\\n)*/g;\n\nconst processedItems = items.map((item) => {\n  const splitText = item.hidden_history.split(\"From\");\n  const cleanedText = splitText.map((text) =>\n    text.replace(emailRegex, \"\").replace(signatureRegex, \"\"),\n  );\n  return { text: cleanedText };\n});\n\nreturn processedItems;\n"
      },
