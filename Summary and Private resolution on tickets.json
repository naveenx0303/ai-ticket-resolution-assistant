    {
      "parameters": {
        "jsCode": "// n8n Function node code\n\nconst inputText = $input.first().json.hidden_history; // Assumes the raw email thread is in a field called \"emailThread\"\n\nfunction extractEmailAddresses(line, prefix) {\n  const regex = new RegExp(prefix + \":[\\\\s\\\\n]*([^\\\\n]*)\", \"i\");\n  const match = line.match(regex);\n  if (match && match[1]) {\n    return match[1]\n      .split(\";\")\n      .map(email => email.trim().replace(/[>\\n]/g, \"\"))\n      .filter(Boolean);\n  }\n  return [];\n}\n\nconst cleanedText = inputText.replace(/[\\n\\r>]+/g, \" \").replace(/\\s+/g, \" \").trim();\n\n// Extract specific lines for From, To, CC, and Description\nconst fromMatch = cleanedText.match(/From:\\s*([^<]*<[^>]+>)/i);\nconst toMatch = cleanedText.match(/To:\\s*([^<]*<[^>]+>)/i);\nconst ccMatch = cleanedText.match(/Cc:\\s*([^<]*<[^>]+>)/i);\n\n// Build result object\nconst result = {\n  fromEmail: fromMatch ? fromMatch[1].trim() : \"\",\n  toEmails: toMatch ? toMatch[1].split(\";\").map(e => e.trim()) : [],\n  ccEmails: ccMatch ? ccMatch[1].split(\";\").map(e => e.trim()) : [],\n  description: cleanedText.substring(0, 500) // Optional: you can define how much context to include\n};\n\nreturn [result];\n"
      },
