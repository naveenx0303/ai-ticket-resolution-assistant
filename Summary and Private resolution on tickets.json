    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst cleanedItems = items.map((item) => {\n  let conversation = item.json.Conversation.join(\" \");\n\n  // Remove dates and time\n  conversation = conversation.replace(\n    /\\d{1,2}\\/\\d{1,2}\\/\\d{4}|\\d{1,2}-\\d{1,2}-\\d{4}|\\d{1,2}:\\d{2} [AP]M/g,\n    \"\",\n  );\n\n  // Remove newline characters\n  conversation = conversation.replace(/\\n/g, \"\");\n\n  // Remove email signatures\n  conversation = conversation.replace(/>.*|Sent from my .*/g, \"\");\n\n  // Remove phone numbers\n  conversation = conversation.replace(\n    /\\(?\\d{3}\\)?[-.\\s]?\\d{3}[-.\\s]?\\d{4}/g,\n    \"\",\n  );\n\n  // Remove disclaimers\n  conversation = conversation.replace(/Disclaimer:.*$/g, \"\");\n\n  return { ...item.json, Conversation: conversation };\n});\n\nreturn cleanedItems;\n"
      },
